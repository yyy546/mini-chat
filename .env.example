# ==============================================================================
# MiniChat Environment Configuration Template
# ==============================================================================
# Instructions:
# 1. Copy this file to .env: `cp .env.example .env`
# 2. Update the values below with your actual configuration.
# 3. DO NOT commit the .env file to version control.
# ==============================================================================

# --- MySQL Configuration ---
MYSQL_ROOT_PASSWORD=root_password_here
MYSQL_DATABASE=minichat
MYSQL_USER=minichat_user
MYSQL_PASSWORD=user_password_here
MYSQL_PORT=3306

# --- Redis Configuration ---
REDIS_PORT=6379
# REDIS_PASSWORD=optional_redis_password

# --- RabbitMQ Configuration ---
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=admin_password_here
RABBITMQ_PORT=5672
RABBITMQ_UI_PORT=15672

# --- Elasticsearch & Kibana Configuration ---
ES_VERSION=8.11.1
ES_PORT=9200
ES_TRANSPORT_PORT=9300
KIBANA_PORT=5601

# --- Application Security ---
# Generate a secure random string for JWT secret
JWT_SECRET=your_super_secret_jwt_key_at_least_32_chars

# --- Aliyun OSS Configuration (Optional) ---
# ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# ALIYUN_OSS_ACCESS_KEY_ID=your_access_key_id
# ALIYUN_OSS_ACCESS_KEY_SECRET=your_access_key_secret
# ALIYUN_OSS_BUCKET_NAME=your_bucket_name
