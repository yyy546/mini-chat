<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.minichat.space.mapper.SpaceLikeMapper">

    <delete id="deleteBatchByPostIds">
        delete from space_like where post_id in
        <foreach collection="expirePostIds" item="expirePostId" open="(" separator="," close=")">
            #{expirePostId}
        </foreach>
    </delete>
</mapper>
